pipeline {
    agent any

    tools {
        jdk 'jdk'
        nodejs 'nodejs'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from GitHub') {
            steps {
                git branch: 'master', url: 'https://github.com/im-ganesh/Book-My-Show-Pipeline.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                    $SCANNER_HOME/bin/sonar-scanner \
                    -Dsonar.projectName=BookMyShow \
                    -Dsonar.projectKey=BookMyShow
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd bookmyshow-app
                npm install
                '''
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                dependencyCheck(
                    odcInstallation: 'dp-check',
                    additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit'
                )

                dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            }
        }

        stage('Trivy File Scan') {
            steps {
                sh 'trivy fs . > trivyfs.txt'
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker', toolName: 'docker') {

                        sh '''
                        docker build --no-cache \
                        -t ganesh996640/bookmyshow:latest \
                        -f bookmyshow-app/Dockerfile \
                        bookmyshow-app

                        docker push ganesh996640/bookmyshow:latest
                        '''
                    }
                }
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker stop bookmyshow || true
                docker rm bookmyshow || true

                docker run -d \
                --restart=always \
                --name bookmyshow \
                -p 3000:3000 \
                ganesh996640/bookmyshow:latest

                docker ps
                '''
            }
        }
    }

    post {
        always {
            emailext(
                attachLog: true,
                subject: "${currentBuild.currentResult}: ${env.JOB_NAME}",
                body: """
                Project : ${env.JOB_NAME}

                Build Number : ${env.BUILD_NUMBER}

                Build URL : ${env.BUILD_URL}
                """,
                to: 'gpeddireddy358@gmail.com',
                attachmentsPattern: 'trivyfs.txt'
            )
        }
    }
}
